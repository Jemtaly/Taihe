# set env
export TAIHE_SOURCE_PATH=$(pwd)

# mkdir out
mkdir -p $TAIHE_SOURCE_PATH/out/bin
mkdir -p $TAIHE_SOURCE_PATH/out/libs/taihe
mkdir -p $TAIHE_SOURCE_PATH/out/share/taihe/runtime/x86-64


# build runtime
cd $TAIHE_SOURCE_PATH/runtime
mkdir -p $TAIHE_SOURCE_PATH/runtime/out
cd $TAIHE_SOURCE_PATH/runtime/out
cmake -DCMAKE_C_COMPILER=/usr/bin/clang -DCMAKE_CXX_COMPILER=/usr/bin/clang++ ../ && make
cp $TAIHE_SOURCE_PATH/runtime/out/libtaihe-rt.so $TAIHE_SOURCE_PATH/out/share/taihe/runtime/x86-64
cp -r $TAIHE_SOURCE_PATH/runtime/include $TAIHE_SOURCE_PATH/out
cp -r $TAIHE_SOURCE_PATH/runtime/src $TAIHE_SOURCE_PATH/out


# build /
cp -r $TAIHE_SOURCE_PATH/compiler $TAIHE_SOURCE_PATH/out/libs/taihe
cd $TAIHE_SOURCE_PATH/out/libs/taihe/compiler
./generate-grammar
poetry build
cp $TAIHE_SOURCE_PATH/scripts/taihec $TAIHE_SOURCE_PATH/out/bin/taihec
chmod u+x $TAIHE_SOURCE_PATH/out/bin/taihec



